<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_factory_order_etl_type_form" model="ir.ui.view">
        <field name="name">factory.order.etl.type.form</field>
        <field name="model">factory.order.etl.type</field>
        <field name="arch" type="xml">
            <form string="訂單種類">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="例如：量產訂單"/>
                        </h1>
                    </div>
                    <group>
                        <group string="匯出格式設定">
                            <field name="template_file" filename="template_filename" widget="binary"/>
                            <field name="template_filename" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_factory_order_etl_type_tree" model="ir.ui.view">
        <field name="name">factory.order.etl.type.tree</field>
        <field name="model">factory.order.etl.type</field>
        <field name="arch" type="xml">
            <tree string="訂單種類設定">
                <field name="name"/>
                <field name="template_filename"/>
            </tree>
        </field>
    </record>

    <!-- Action -->
    <record id="action_factory_order_etl_type" model="ir.actions.act_window">
        <field name="name">訂單種類設定</field>
        <field name="res_model">factory.order.etl.type</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_factory_order_etl_type"
              name="訂單種類設定"
              parent="menu_factory_order_etl_root"
              action="action_factory_order_etl_type"
              sequence="20"/>

</odoo>
