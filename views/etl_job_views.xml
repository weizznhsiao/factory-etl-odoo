<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Sequence for ETL Job -->
    <record id="seq_factory_order_etl_job" model="ir.sequence">
        <field name="name">工廠訂單 ETL 作業</field>
        <field name="code">factory.order.etl.job</field>
        <field name="prefix">JOB/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Form View -->
    <record id="view_factory_order_etl_job_form" model="ir.ui.view">
        <field name="name">factory.order.etl.job.form</field>
        <field name="model">factory.order.etl.job</field>
        <field name="arch" type="xml">
            <form string="工廠訂單 ETL 作業">
                <header>
                    <button name="action_process" type="object" string="執行匯入" class="oe_highlight" attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>

                    <!-- Upload State -->
                    <group string="上傳訂單檔案" attrs="{'invisible': [('state', '!=', 'draft')]}">
                        <div class="alert alert-info" role="alert" colspan="2">
                            請選擇「訂單種類」，並直接上傳原始訂單檔案（支援 PDF、XLS、XLSX、XLSB，可一次選取多個檔案）。
                        </div>
                        <field name="order_type_id" options="{'no_create': True, 'no_open': True}"/>
                        <field name="order_files" widget="many2many_binary" string="原始訂單檔案"/>
                    </group>

                    <!-- Done State -->
                    <group string="ETL 作業已完成" attrs="{'invisible': [('state', '!=', 'done')]}">
                        <div class="alert alert-success" role="alert" colspan="2">
                            ETL 作業已順利完成！請點擊下方連結下載轉換後的 Excel 檔案。
                        </div>
                        <field name="output_file" filename="output_filename" widget="binary"/>
                        <field name="output_filename" invisible="1"/>
                        <field name="log_summary"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_factory_order_etl_job_tree" model="ir.ui.view">
        <field name="name">factory.order.etl.job.tree</field>
        <field name="model">factory.order.etl.job</field>
        <field name="arch" type="xml">
            <tree string="工廠訂單 ETL 作業列表" decoration-info="state == 'draft'" decoration-success="state == 'done'">
                <field name="name"/>
                <field name="create_date" string="建立時間"/>
                <field name="order_type_id"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'done'"/>
            </tree>
        </field>
    </record>

    <!-- Action -->
    <record id="action_factory_order_etl_job" model="ir.actions.act_window">
        <field name="name">工廠訂單 ETL 作業列表</field>
        <field name="res_model">factory.order.etl.job</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                建立您的第一個 ETL 作業
            </p>
            <p>
                選擇您的訂單種類並上傳原始訂單檔案（Excel / PDF），即可自動轉換為 ERP 可匯入的 Excel 檔案。
            </p>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_factory_order_etl_root" name="訂單轉檔" sequence="10"/>
    <menuitem id="menu_factory_order_etl_jobs" name="ETL 作業記錄" parent="menu_factory_order_etl_root" action="action_factory_order_etl_job" sequence="10"/>

</odoo>
